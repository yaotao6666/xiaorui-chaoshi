# 应用程序配置
APP_NAME=chaoshi_api
APP_HOST=0.0.0.0
APP_PORT=8080
APP_ENV=production
APP_DEBUG=false

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USER=chaoshi
DB_PASSWORD=change-me
DB_NAME=chaoshi_api
DB_CHARSET=utf8mb4
DB_MAX_IDLE=10
DB_MAX_OPEN=100
DB_LIFE_TIME=3600

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0

# JWT 配置
JWT_SECRET=change-me
JWT_EXPIRE=720

# 本地文件存储配置
UPLOAD_ROOT_DIR=/app/uploads
UPLOAD_PUBLIC_BASE_URL=https://fzyyc.jxxme.cn
UPLOAD_URL_PREFIX=/uploads

# 微信支付配置（生产必须为 HTTPS 可达地址）
WECHAT_PAY_SP_MCH_ID=change-me
WECHAT_PAY_SP_API_V3_KEY=change-me
WECHAT_PAY_SP_CERT_SERIAL_NO=change-me
WECHAT_PAY_SP_PRIVATE_KEY=/app/certs/apiclient_key.pem
WECHAT_PAY_SP_PUBLIC_KEY=/app/certs/pub_key.pem
WECHAT_PAY_SP_CALLBACK_URL=https://fzyyc.jxxme.cn/api/v1/notify/payment

# 微信小程序配置（当前 Go 服务统一使用该组配置对接微信小程序登录）
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me
