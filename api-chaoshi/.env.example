# 应用程序配置
APP_NAME=chaoshi_api
APP_HOST=0.0.0.0
APP_PORT=8080
APP_ENV=development
APP_DEBUG=true

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=chaoshi
DB_PASSWORD=chaoshi123
DB_NAME=chaoshi_api
DB_CHARSET=utf8mb4
DB_MAX_IDLE=10
DB_MAX_OPEN=100
DB_LIFE_TIME=3600

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE=720

# 本地文件存储配置
UPLOAD_ROOT_DIR=./uploads
UPLOAD_PUBLIC_BASE_URL=http://127.0.0.1:8080
UPLOAD_URL_PREFIX=/uploads

# 微信支付配置
WECHAT_PAY_SP_MCH_ID=your-sp-mch-id
WECHAT_PAY_SP_CALLBACK_URL=http://127.0.0.1:8080/api/v1/notify/payment

# 微信支付配置 - APIV3密钥
WECHAT_PAY_SP_API_V3_KEY=your-api-key-v3
# 公钥ID
WECHAT_PAY_SP_PUBLIC_KEY_ID=your-public-key-id
# 公钥
WECHAT_PAY_SP_PUBLIC_KEY=pub_key.pem

# 微信小程序配置（当前 Go 服务统一使用该组配置对接微信小程序登录）
WECHAT_APP_ID=your-miniapp-appid
WECHAT_APP_SECRET=your-miniapp-appsecret
